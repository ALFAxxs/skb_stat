msgid "&quot;Bemor&quot;"
msgstr "&quot;Пациент&quot;"

msgid ""
"&quot;Bemor&quot; &quot;Ijrochi&quot;ning barcha pullik xizmatlari "
"ko'rsatilgan preyskurant bilan tanishib chiqgandan so'ng, ko'rsatilgan "
"tibbiy xizmatlarning miqdori va narxlari bilan kelishib, mazkur shartnomani "
"imzolaydi."
msgstr ""
"&quot;Пациент&quot;, ознакомившись с прейскурантом всех платных услуг "
"&quot;Исполнителя&quot;, согласившись с объёмом и стоимостью указанных "
"медицинских услуг, подписывает настоящий договор."

msgid "&quot;Bemor&quot; quyidagi huquqlarga ega:"
msgstr "&quot;Пациент&quot; имеет следующие права:"

msgid "&quot;Bemor&quot;ning majburiyatlari:"
msgstr "Обязанности &quot;Пациента&quot;:"

